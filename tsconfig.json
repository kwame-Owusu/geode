{
	"compilerOptions": {
		"baseUrl": ".",
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "node",
		"lib": ["DOM", "ES2020"],
		"strict": true,
		"noImplicitAny": true,
		"importHelpers": true,
		"isolatedModules": true,
		"inlineSourceMap": true,
		"inlineSources": true
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules", "build"]
}
